{
    "name": "titancrew",
    "private": true,
    "scripts": {
          "build": "npm --prefix apps/dashboard run build && npm --prefix packages/agents run build",
          "dev": "turbo run dev",
          "lint": "npm --prefix apps/dashboard run lint",
          "type-check": "npm --prefix apps/dashboard run type-check && npm --prefix packages/agents run type-check",
          "agents": "node packages/agents/dist/src/meta-swarm/MetaSwarmOrchestrator.js",
          "test:e2e": "npx ts-node launch/testing/e2e-simulation.ts"
    },
    "devDependencies": {
          "turbo": "^2.1.3",
          "typescript": "^5.4.0",
          "@types/node": "^20.0.0",
          "prettier": "^3.2.0"
    },
    "packageManager": "pnpm@9.0.0",
    "engines": {
          "node": ">=20.0.0",
          "pnpm": ">=9.0.0"
    }
}
