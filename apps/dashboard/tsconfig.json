{
    "compilerOptions": {
          "target": "ES2017",
          "lib": ["dom", "dom.iterable", "esnext"],
          "allowJs": true,
          "skipLibCheck": true,
          "strict": true,
          "noEmit": true,
          "esModuleInterop": true,
          "module": "esnext",
          "moduleResolution": "bundler",
          "resolveJsonModule": true,
          "isolatedModules": true,
          "jsx": "preserve",
          "incremental": false,
          "plugins": [
                  {
                            "name": "next"
                  }
          ],
          "paths": {
                  "@/*": ["./*"],
                  "@titancrew/agents/src/tools/integrations/GoogleCalendarAdapter": ["./lib/stubs/GoogleCalendarAdapter"],
                  "@titancrew/agents/src/tools/integrations/QuickBooksAdapter": ["./lib/stubs/QuickBooksAdapter"]
          }
    },
    "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
    "exclude": ["node_modules"]
}
