# ─────────────────────────────────────────────────────────────
# TitanCrew — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or .env.production to git.
# See DEPLOY.md for where to get each value.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# ── AI / LLM ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Plan price IDs — must match product names in Stripe dashboard.
# Code also checks fallback names: STRIPE_PRICE_LITE, STRIPE_PRICE_GROWTH, STRIPE_PRICE_SCALE
STRIPE_LITE_PRICE_ID=price_xxx
STRIPE_GROWTH_PRICE_ID=price_xxx
STRIPE_SCALE_PRICE_ID=price_xxx

# ── Twilio ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ── Google OAuth (Calendar) ───────────────────────────────────
# NOTE: The redirect URI is computed at runtime as:
#   ${NEXT_PUBLIC_APP_URL}/api/integrations/google-calendar?action=callback
# You must register EXACTLY that URI in GCP Console → OAuth 2.0 Client → Authorized Redirect URIs.
# For production: https://app.titancrew.ai/api/integrations/google-calendar?action=callback
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# ── QuickBooks Online ─────────────────────────────────────────
# NOTE: The redirect URI is computed at runtime as:
#   ${NEXT_PUBLIC_APP_URL}/api/integrations/quickbooks?action=callback
# You must register EXACTLY that URI in Intuit Developer → OAuth 2.0 → Redirect URIs.
# For production: https://app.titancrew.ai/api/integrations/quickbooks?action=callback
QBO_CLIENT_ID=xxx
QBO_CLIENT_SECRET=xxx
QBO_ENV=production

# ── Email (SendGrid) ──────────────────────────────────────────
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=stephen@titancrew.ai
SENDGRID_FROM_NAME=Stephen at TitanCrew

# ── Suppliers (optional at launch) ───────────────────────────
FERGUSON_API_KEY=
GRAINGER_API_KEY=

# ── Apify / Social Posting (optional at launch) ───────────────
APIFY_API_TOKEN=
APIFY_FACEBOOK_ACTOR_ID=
APIFY_NEXTDOOR_ACTOR_ID=

# ── Reddit (optional at launch) ───────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ── LinkedIn (optional at launch) ─────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# ── LangSmith observability ───────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__xxx
LANGCHAIN_PROJECT=titancrew-prod

# ── Agent Runtime (Railway/Fly.io) ────────────────────────────
# URL of the MetaSwarmOrchestrator Express server.
# Dashboard calls POST ${AGENT_API_URL}/crews/trigger to dispatch agent events.
AGENT_API_URL=https://your-agent-service.up.railway.app
# Shared secret between dashboard and agent runtime for auth.
AGENT_API_SECRET=generate-a-random-secret-here

# ── n8n Webhooks (optional — used by OnboarderAgent) ─────────
N8N_SCHEDULE_WEBHOOK=
N8N_CHECKIN_WEBHOOK=

# ── Internal ──────────────────────────────────────────────────
FOUNDER_PHONE=+1xxxxxxxxxx
NEXT_PUBLIC_APP_URL=https://app.titancrew.ai
NODE_ENV=production
