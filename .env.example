# ─────────────────────────────────────────────────────────────
# TitanCrew — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or .env.production to git.
# See DEPLOY.md for where to get each value.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# ── AI / LLM ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_BASIC_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_ELITE_PRICE_ID=price_xxx

# ── Twilio ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Google OAuth (Calendar) ───────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_REDIRECT_URI=https://app.titancrew.ai/api/integrations/google-calendar

# ── QuickBooks Online ─────────────────────────────────────────
QBO_CLIENT_ID=xxx
QBO_CLIENT_SECRET=xxx
QBO_REDIRECT_URI=https://app.titancrew.ai/api/integrations/quickbooks
QBO_ENVIRONMENT=production

# ── Email (SendGrid) ──────────────────────────────────────────
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=stephen@titancrew.ai
SENDGRID_FROM_NAME=Stephen at TitanCrew

# ── Suppliers (optional at launch) ───────────────────────────
FERGUSON_API_KEY=
GRAINGER_API_KEY=

# ── Apify / Social Posting (optional at launch) ───────────────
APIFY_API_TOKEN=
APIFY_FACEBOOK_ACTOR_ID=
APIFY_NEXTDOOR_ACTOR_ID=

# ── Reddit (optional at launch) ───────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# ── LinkedIn (optional at launch) ─────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# ── LangSmith observability ───────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__xxx
LANGCHAIN_PROJECT=titancrew-prod

# ── Internal ──────────────────────────────────────────────────
FOUNDER_PHONE=+1xxxxxxxxxx
NEXT_PUBLIC_APP_URL=https://app.titancrew.ai
API_BASE_URL=https://api.titancrew.ai
NODE_ENV=production
